        <mxCell id="74" value="イメージ push" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F4B400;fontStyle=1;fontSize=10;" edge="1" source="50" target="40" parent="1">
          <mxGeometry relative="1" as="geometry" />
