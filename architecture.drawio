        <!-- Cloud Run → Container Registry (pull) -->
        <mxCell id="73" value="イメージ pull" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#4285F4;fontStyle=1;fontSize=10;dashed=1;" edge="1" source="20" target="40" parent="1">
          <mxGeometry relative="1" as="geometry" />
