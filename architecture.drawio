        <!-- Cloud Build → Cloud Run (deploy) -->
        <mxCell id="76" value="gcloud run deploy" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F4B400;fontStyle=1;fontSize=10;" edge="1" source="50" target="20" parent="1">
