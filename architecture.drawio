        <!-- 開発者 → Cloud Build -->
        <mxCell id="75" value="gcloud builds submit" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F4B400;fontStyle=1;fontSize=10;" edge="1" source="60" target="50" parent="1">
          <mxGeometry relative="1" as="geometry" />
